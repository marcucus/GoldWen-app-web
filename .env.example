# GoldWen Web — Environment Configuration
# Copy this file to .env.local and fill in the values

# App Store / Google Play links
# Leave empty to show "coming soon" disabled buttons
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_GOOGLE_PLAY_URL=

# Site URL (used for canonical tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://goldwen.app

# Footer social proof stats (shown in the footer)
NEXT_PUBLIC_STAT_USERS=10K+
NEXT_PUBLIC_STAT_RATING=4.9★
NEXT_PUBLIC_STAT_SATISFACTION=95%

# A/B Testing — set to 'b' to enable variant B
NEXT_PUBLIC_AB_HERO=a
NEXT_PUBLIC_AB_CTA=a

# Contact form — SMTP (requires: npm install nodemailer @types/nodemailer)
CONTACT_EMAIL_TO=support@goldwen.app
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password
EMAIL_FROM=noreply@goldwen.app
